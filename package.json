{
  "name": "payload-plugins",
  "version": "0.3.0",
  "private": true,
  "description": "A monorepo of composable @pro-laico/* Payload CMS plugins, test apps, and documentation.",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome check .",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "test": "turbo run test",
    "docs": "pnpm --filter docs dev",
    "clean": "rimraf --glob \"packages/*/dist\" \"packages/*/*.tsbuildinfo\" \"examples/*/.next\" \"examples/*/*.tsbuildinfo\" \"tools/*/*.tsbuildinfo\" \"docs/.next\" \"docs/*.tsbuildinfo\" \".turbo\"",
    "clean:all": "pnpm clean && rimraf --glob node_modules \"packages/*/node_modules\" \"examples/*/node_modules\" \"docs/node_modules\" \"tools/*/node_modules\"",
    "reinstall": "pnpm clean:all && pnpm install",
    "audit": "pnpm audit -P",
    "audit:moderate": "pnpm audit -P --audit-level moderate",
    "audit:high": "pnpm audit -P --audit-level high",
    "audit:critical": "pnpm audit -P --audit-level critical",
    "release": "pnpm --filter @tools/releaser release",
    "publish-packages": "pnpm --filter @tools/releaser publish-packages",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.10.0"
  },
  "engines": {
    "node": "24.x"
  }
}
