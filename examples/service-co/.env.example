# Copy to .env.local. The site uses a local SQLite file and local-disk uploads, so it boots and
# seeds with these values as-is — no external services required. Mux is the one optional add-on
# (video); leave the MUX_* vars unset and the site runs fine, just without the showreel.

# Payload encryption secret (any random string for local dev).
PAYLOAD_SECRET=dev-secret-change-me

# SQLite database file.
DATABASE_URI=file:./service-co.db

# The site URL (used for CORS, the fonts export, and Mux CORS origin).
NEXT_PUBLIC_SERVER_URL=http://localhost:3060

# Set to true to enable the admin "Seed your database" button / POST /api/seed.
ENABLE_SEED=true

# ── Mux (optional) ──────────────────────────────────────────────────────────────
# Set these to ingest and play video. With them present, `pnpm seed` also uploads the sample
# showreel to Mux and wires it to the site. Without them, the video sections are simply skipped.
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# MUX_WEBHOOK_SECRET=
# Signed playback also needs: MUX_SIGNING_KEY, MUX_PRIVATE_KEY
