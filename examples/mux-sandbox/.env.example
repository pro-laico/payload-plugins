# Copy to .env.local. The example uses a local SQLite file and local-disk uploads.
# Real uploads/playback need a Mux account, but dummy values are enough to boot the app.

# Payload encryption secret (any random string for local dev).
PAYLOAD_SECRET=dev-secret-change-me

# SQLite database file.
DATABASE_URI=file:./mux-sandbox.db

# The site URL, used as the Mux upload CORS origin.
NEXT_PUBLIC_SERVER_URL=http://localhost:3051

# Mux credentials (from the Mux dashboard). Placeholders boot the app; real values are
# required to actually upload and play back video.
MUX_TOKEN_ID=test-token-id
MUX_TOKEN_SECRET=test-token-secret
MUX_WEBHOOK_SIGNING_SECRET=test-webhook-secret

# For signed playback, also set these (and uploadSettings.new_asset_settings.playback_policy).
# MUX_JWT_KEY_ID=
# MUX_JWT_KEY=
