# Copy to .env.local. The example uses a local SQLite file and local-disk uploads.
# Real uploads/playback need a Mux account, but dummy values are enough to boot the app.

# Payload encryption secret (any random string for local dev).
PAYLOAD_SECRET=dev-secret-change-me

# SQLite database file.
DATABASE_URI=file:./mux-sandbox.db

# The site URL — the plugin uses it as the default Mux upload CORS origin.
NEXT_PUBLIC_SERVER_URL=http://localhost:3051

# Master kill switch for the DESTRUCTIVE seed. Both the seed buttons and POST /api/seed
# refuse to run unless this is exactly "true".
ENABLE_SEED=true

# Mux credentials (from the Mux dashboard). The plugin and seeder read these standard MUX_*
# names automatically — no need to pass them to muxVideoPlugin(). The app boots without them
# (uploads/playback obviously need real values).
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# For signed playback, also set these (and pass new_asset_settings.playback_policy: ['signed']).
# MUX_SIGNING_KEY=
# MUX_PRIVATE_KEY=
