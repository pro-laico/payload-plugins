# Copy to .env.local. The example uses a local SQLite file and local-disk uploads,
# so no external services are required.

# Payload encryption secret (any random string for local dev).
PAYLOAD_SECRET=dev-secret-change-me

# SQLite database file.
DATABASE_URI=file:./seed-sandbox.db

# Master kill switch for the DESTRUCTIVE seed. Both `pnpm seed` and POST /api/seed
# refuse to run unless this is exactly "true".
ENABLE_SEED=true
