# Copy to .env.local. The example uses a local SQLite file and local-disk uploads — no external
# services, so it boots and seeds with these values as-is.

# Payload encryption secret (any random string for local dev).
PAYLOAD_SECRET=dev-secret-change-me

# SQLite database file.
DATABASE_URI=file:./icons-sandbox.db

# The site URL.
NEXT_PUBLIC_SERVER_URL=http://localhost:3054

# Master kill switch for the DESTRUCTIVE seed. Both the seed buttons and POST /api/seed
# refuse to run unless this is exactly "true".
ENABLE_SEED=true
