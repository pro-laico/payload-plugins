# Copy to .env.local. The example uses a local SQLite file and local-disk uploads —
# no external services. It boots and serves optimized images entirely on localhost.

# Payload encryption secret (any random string for local dev).
PAYLOAD_SECRET=dev-secret-change-me

# SQLite database file.
DATABASE_URI=file:./images-sandbox.db

# The site URL — the transform endpoint self-fetches the original from here when the
# storage adapter reports a relative/cloud URL. Local-disk uploads don't need it, but
# set it so production (and cloud storage) works.
NEXT_PUBLIC_SERVER_URL=http://localhost:31052

# Turn on the in-app seed endpoint + admin "Seed your database" button.
ENABLE_SEED=true

# Optional: tune the on-demand transform endpoint.
# IMAGES_TRANSFORM_CONCURRENCY=   # max concurrent Sharp transforms (default cpus - 1)
# IMAGES_SHARP_CONCURRENCY=       # per-image libvips threads (default 1; 0 = CPU cores)
