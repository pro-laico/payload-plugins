{
  "name": "images-sandbox",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 31052",
    "build": "next build",
    "start": "next start -p 31052",
    "payload": "cross-env NODE_OPTIONS=\"--no-deprecation --conditions=react-server\" payload",
    "generate:types": "pnpm payload generate:types",
    "generate:importmap": "pnpm payload generate:importmap",
    "test": "node -e \"try{require('fs').rmSync('.vitest.db')}catch{}\" && cross-env PAYLOAD_SECRET=test-secret DATABASE_URI=file:./.vitest.db IMAGES_PREWARM_FLUSH_MS=100 vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "^3.86.0",
    "@payloadcms/next": "^3.86.0",
    "@payloadcms/richtext-lexical": "^3.86.0",
    "@payloadcms/ui": "^3.86.0",
    "@pro-laico/payload-images": "workspace:*",
    "@pro-laico/payload-seed": "workspace:*",
    "@pro-laico/sandbox-shell": "workspace:*",
    "cross-env": "^10.1.0",
    "graphql": "^16.14.2",
    "next": "^16.2.10",
    "payload": "^3.86.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
