# Copy to .env.local. The example uses a local SQLite file and local-disk uploads — no external
# services are needed to boot, upload fonts, seed, or serve them.

# Payload encryption secret (any random string for local dev). Also the Bearer secret the fonts
# export endpoint + the payload-fonts-download CLI authenticate with.
PAYLOAD_SECRET=dev-secret-change-me

# SQLite database file.
DATABASE_URI=file:./fonts-sandbox.db

# The site URL.
NEXT_PUBLIC_SERVER_URL=http://localhost:3947

# Base URL the `generate:fonts` CLI fetches the active fonts from (the running app).
FONT_DOWNLOAD_URL=http://localhost:3947

# DESTRUCTIVE seed kill-switch. Set to true to enable the admin "Seed your database" button,
# the frontend "Seed the database" button, and POST /api/seed (wipes + reseeds the font data).
ENABLE_SEED=true
