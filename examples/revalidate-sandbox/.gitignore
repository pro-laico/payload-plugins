# Local SQLite DB (created at runtime)
*.db
*.db-journal
*.db-wal
*.db-shm

# Uploaded files (written at runtime to local-disk storage). /media/ is the sandbox's own
# upload collection; /icon/ is payload-icons' and /images/ + /generated-images/ are
# payload-images' default staticDirs under cwd. Root-anchored so the assets/* seed
# fixtures stay tracked.
/media/
/icon/
/images/
/generated-images/

.env
.env*.local
next-env.d.ts
*.tsbuildinfo
