{
  "name": "revalidate-sandbox",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3055",
    "build": "next build",
    "start": "next start -p 3055",
    "payload": "cross-env NODE_OPTIONS=\"--no-deprecation --conditions=react-server\" payload",
    "generate:types": "pnpm payload generate:types",
    "generate:importmap": "pnpm payload generate:importmap",
    "seed": "pnpm payload seed",
    "test": "cross-env PAYLOAD_SECRET=test-secret DATABASE_URI=file:./.vitest.db vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "^3.85.2",
    "@payloadcms/next": "^3.85.2",
    "@payloadcms/richtext-lexical": "^3.85.2",
    "@payloadcms/ui": "^3.85.2",
    "@pro-laico/payload-dev-tools": "workspace:*",
    "@pro-laico/payload-icons": "workspace:*",
    "@pro-laico/payload-images": "workspace:*",
    "@pro-laico/payload-revalidate": "workspace:*",
    "@pro-laico/payload-seed": "workspace:*",
    "@pro-laico/sandbox-shell": "workspace:*",
    "cross-env": "^10.1.0",
    "graphql": "^16.14.2",
    "next": "^16.2.10",
    "payload": "^3.85.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
