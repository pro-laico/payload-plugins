{
  "name": "@pro-laico/payload-images",
  "version": "0.3.0",
  "description": "Image optimization for Payload CMS: an Images upload collection that stores only the original, an on-demand Sharp transform endpoint (focal-aware crop, format negotiation, built-in LQIP placeholders), a durable variant cache with two-way purge, an admin focal-point picker, and a responsive <ResponsiveImage> component.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/payload-plugins.git",
    "directory": "packages/payload-images"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "plugin",
    "image",
    "images",
    "sharp",
    "optimization",
    "webp",
    "avif",
    "responsive"
  ],
  "sideEffects": false,
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./components/image": {
        "types": "./dist/components/image.d.ts",
        "import": "./dist/components/image.js",
        "default": "./dist/components/image.js"
      },
      "./utils/urls": {
        "types": "./dist/lib/urls/index.d.ts",
        "import": "./dist/lib/urls/index.js",
        "default": "./dist/lib/urls/index.js"
      },
      "./admin/focalPreview": {
        "types": "./dist/components/admin/focalPreview/index.d.ts",
        "import": "./dist/components/admin/focalPreview/index.js",
        "default": "./dist/components/admin/focalPreview/index.js"
      },
      "./admin/presetManager": {
        "types": "./dist/components/admin/presetManager/index.d.ts",
        "import": "./dist/components/admin/presetManager/index.js",
        "default": "./dist/components/admin/presetManager/index.js"
      }
    }
  },
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/image": {
      "types": "./dist/components/image.d.ts",
      "import": "./src/components/image.tsx",
      "default": "./src/components/image.tsx"
    },
    "./utils/urls": {
      "types": "./dist/lib/urls/index.d.ts",
      "import": "./src/lib/urls/index.ts",
      "default": "./src/lib/urls/index.ts"
    },
    "./admin/focalPreview": {
      "types": "./dist/components/admin/focalPreview/index.d.ts",
      "import": "./src/components/admin/focalPreview/index.tsx",
      "default": "./src/components/admin/focalPreview/index.tsx"
    },
    "./admin/presetManager": {
      "types": "./dist/components/admin/presetManager/index.d.ts",
      "import": "./src/components/admin/presetManager/index.tsx",
      "default": "./src/components/admin/presetManager/index.tsx"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:types && pnpm build:swc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck"
  },
  "peerDependencies": {
    "@payloadcms/ui": "^3.0.0",
    "next": ">=15.0.0",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.85.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "next": "^16.2.10",
    "payload": "^3.85.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
