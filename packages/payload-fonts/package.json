{
  "name": "@pro-laico/payload-fonts",
  "version": "0.4.1",
  "description": "Custom fonts for Payload CMS: a Font typeface collection that subsets uploaded files to served WOFF2s, an optional fontSet global, an export endpoint + CLI that writes the active fonts to disk for next/font/local, and declarative seeding.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/payload-plugins.git",
    "directory": "packages/payload-fonts"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "plugin",
    "fonts",
    "font",
    "woff2",
    "next-font"
  ],
  "sideEffects": [
    "*.scss",
    "*.css"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./admin/FontOriginalUpload": {
        "types": "./dist/components/admin/FontOriginalUpload.d.ts",
        "import": "./dist/components/admin/FontOriginalUpload.js",
        "default": "./dist/components/admin/FontOriginalUpload.js"
      },
      "./PreviewFonts": {
        "types": "./dist/components/PreviewFonts.d.ts",
        "import": "./dist/components/PreviewFonts.js",
        "default": "./dist/components/PreviewFonts.js"
      }
    }
  },
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "bin": {
    "payload-fonts-download": "./dist/scripts/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./admin/FontOriginalUpload": {
      "types": "./dist/components/admin/FontOriginalUpload.d.ts",
      "import": "./src/components/admin/FontOriginalUpload.tsx",
      "default": "./src/components/admin/FontOriginalUpload.tsx"
    },
    "./PreviewFonts": {
      "types": "./dist/components/PreviewFonts.d.ts",
      "import": "./src/components/PreviewFonts.tsx",
      "default": "./src/components/PreviewFonts.tsx"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:types && pnpm build:swc && pnpm build:assets",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck",
    "build:assets": "copyfiles -u 1 \"src/**/*.{scss,css}\" dist"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "fontkit": "^2.0.4",
    "subset-font": "^2.5.0"
  },
  "peerDependencies": {
    "@payloadcms/ui": "^3.0.0",
    "next": ">=15.0.0",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@payloadcms/db-sqlite": "^3.86.0",
    "@payloadcms/ui": "^3.86.0",
    "@types/fontkit": "^2.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/subset-font": "^2.3.0",
    "next": "^16.2.10",
    "payload": "^3.86.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18"
  }
}
