{
  "name": "@pro-laico/payload-revalidate",
  "version": "0.2.0",
  "description": "Surgical Next.js cache revalidation for Payload CMS: auto-attached hooks that bust exactly the tags a change touches, cacheTag helpers that auto-collect embedded-doc dependency tags inside 'use cache' getters, and a dependency map showing what revalidates when.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/payload-plugins.git",
    "directory": "packages/payload-revalidate"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "plugin",
    "revalidate",
    "cache",
    "nextjs",
    "cacheTag",
    "revalidateTag"
  ],
  "sideEffects": false,
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./cache": {
        "types": "./dist/cache/index.d.ts",
        "import": "./dist/cache/index.js",
        "default": "./dist/cache/index.js"
      }
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./cache": {
      "import": "./src/cache/index.ts",
      "types": "./src/cache/index.ts",
      "default": "./src/cache/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:types && pnpm build:swc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck"
  },
  "dependencies": {
    "server-only": "^0.0.1"
  },
  "peerDependencies": {
    "next": ">=16.0.0",
    "payload": "^3.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "next": "^16.2.9",
    "payload": "^3.85.1",
    "react": "^19.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
