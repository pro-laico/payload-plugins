{
  "name": "@pro-laico/payload-seed",
  "version": "0.4.0",
  "description": "Schema-aware, type-safe seeding plugin for Payload CMS: typed cross-file references with dependency tracking, robust media uploads, a POST /api/seed endpoint, and a SeedRegistry injected into payload-types.ts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/payload-plugins.git",
    "directory": "packages/payload-seed"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "plugin",
    "seed",
    "seeding",
    "fixtures"
  ],
  "sideEffects": false,
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./components/SeedButton": {
        "types": "./dist/components/SeedButton.d.ts",
        "import": "./dist/components/SeedButton.js",
        "default": "./dist/components/SeedButton.js"
      }
    }
  },
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/SeedButton": {
      "types": "./dist/components/SeedButton.d.ts",
      "import": "./src/components/SeedButton.tsx",
      "default": "./src/components/SeedButton.tsx"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:types && pnpm build:swc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck"
  },
  "peerDependencies": {
    "@payloadcms/ui": "^3.0.0",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.86.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "payload": "^3.86.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18"
  }
}
