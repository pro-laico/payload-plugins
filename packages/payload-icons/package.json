{
  "name": "@pro-laico/payload-icons",
  "version": "0.2.0",
  "description": "SVG icons for Payload CMS: an Icon upload collection that optimizes and sanitizes SVGs on save (svgo + viewBox tightening + currentColor theming), a drop-in <Icon name> server component that fetches and inlines the SVG, and one-line declarative seeding via @pro-laico/payload-seed.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/payload-plugins.git",
    "directory": "packages/payload-icons"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "plugin",
    "icons",
    "svg",
    "svgo",
    "upload"
  ],
  "sideEffects": false,
  "type": "module",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./components/Icon": {
        "types": "./dist/components/Icon.d.ts",
        "import": "./dist/components/Icon.js",
        "default": "./dist/components/Icon.js"
      },
      "./cache": {
        "types": "./dist/cache/index.d.ts",
        "import": "./dist/cache/index.js",
        "default": "./dist/cache/index.js"
      },
      "./admin/iconRowLabel": {
        "types": "./dist/components/admin/iconRowLabel.d.ts",
        "import": "./dist/components/admin/iconRowLabel.js",
        "default": "./dist/components/admin/iconRowLabel.js"
      },
      "./admin/iconUsagePanel": {
        "types": "./dist/components/admin/iconUsagePanel.d.ts",
        "import": "./dist/components/admin/iconUsagePanel.js",
        "default": "./dist/components/admin/iconUsagePanel.js"
      },
      "./admin/iconPreview": {
        "types": "./dist/components/admin/iconPreview.d.ts",
        "import": "./dist/components/admin/iconPreview.js",
        "default": "./dist/components/admin/iconPreview.js"
      }
    },
    "bin": {
      "payload-icons-scan": "./dist/scan/cli.js"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/Icon": {
      "import": "./src/components/Icon.tsx",
      "types": "./src/components/Icon.tsx",
      "default": "./src/components/Icon.tsx"
    },
    "./cache": {
      "import": "./src/cache/index.ts",
      "types": "./src/cache/index.ts",
      "default": "./src/cache/index.ts"
    },
    "./admin/iconRowLabel": {
      "import": "./src/components/admin/iconRowLabel.tsx",
      "types": "./src/components/admin/iconRowLabel.tsx",
      "default": "./src/components/admin/iconRowLabel.tsx"
    },
    "./admin/iconUsagePanel": {
      "import": "./src/components/admin/iconUsagePanel.tsx",
      "types": "./src/components/admin/iconUsagePanel.tsx",
      "default": "./src/components/admin/iconUsagePanel.tsx"
    },
    "./admin/iconPreview": {
      "import": "./src/components/admin/iconPreview.tsx",
      "types": "./src/components/admin/iconPreview.tsx",
      "default": "./src/components/admin/iconPreview.tsx"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:types && pnpm build:swc",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:swc": "swc ./src -d ./dist --config-file ../../.swcrc --strip-leading-paths",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --noCheck"
  },
  "dependencies": {
    "server-only": "^0.0.1",
    "svg-path-bbox": "^2.1.0",
    "svgo": "^4.0.1"
  },
  "peerDependencies": {
    "@payloadcms/ui": "^3.0.0",
    "next": ">=15.0.0",
    "payload": "^3.0.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@payloadcms/ui": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@payloadcms/ui": "^3.85.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "next": "^16.2.10",
    "payload": "^3.85.2",
    "react": "^19.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
